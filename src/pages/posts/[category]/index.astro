---
import { isBefore } from "date-fns";
import { type GetStaticPaths } from "astro";
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";

export const getStaticPaths: GetStaticPaths = async () => {
    const posts = await getCollection("blog");

    // Extract unique categories
    const categories = Array.from(
        new Set(posts.map((p) => p.slug.split("/")[0]))
    );

    return categories.map((category) => ({
        params: { category },
        props: {
            category,
            posts: posts
                .filter((p) => {
                    const cat = p.slug.split("/")[0];
                    if (import.meta.env.PROD) {
                        return cat === category && !!p.data.publish;
                    }
                    return cat === category;
                })
                .sort((a, b) =>
                    isBefore(a.data.pubDate, b.data.pubDate) ? 1 : -1
                ),
        },
    }));
};

interface Props {
    category: string;
    posts: CollectionEntry<"blog">[];
}

const { category, posts }: Props = Astro.props;

const categoryInfo: Record<string, { emoji: string; name: string }> = {
    ai: { emoji: "🤖", name: "AI & Assistants" },
    engineering: { emoji: "⚙️", name: "Software Engineering" },
    trading: { emoji: "📈", name: "Trading & Markets" },
};

const info = categoryInfo[category] || { emoji: "📝", name: category };
---

<Layout title={`${info.name} - Blog`}>
    <main
        class="flex flex-col gap-6 items-center w-full max-w-screen-md mx-auto px-2"
    >
        <div class="flex flex-col items-center gap-2">
            <span class="text-5xl">{info.emoji}</span>
            <h1 class="text-xl font-bold">{info.name}</h1>
            <p class="text-sm text-gray-600">
                {posts.length} {posts.length === 1 ? "post" : "posts"}
            </p>
        </div>

        <a href="/posts" class="link link-sm">← Back to all posts</a>

        <ul class="flex flex-col gap-8 w-full">
            {
                posts.map((b) => (
                    <li class="w-full flex flex-row gap-4 items-center">
                        <div class="flex flex-col gap-1 items-center p-4 border rounded-md bg-white">
                            <span class="text-3xl font-extrabold">
                                {b.data.pubDate.getDate()}
                            </span>
                            <span class="text-sm">
                                {b.data.pubDate.toLocaleString("default", {
                                    year: "numeric",
                                    month: "short",
                                })}
                            </span>
                        </div>

                        <div class="flex flex-1 flex-col gap-2 justify-center">
                            <div class="flex flex-row gap-1 flex-wrap">
                                <a
                                    href={`/posts/${b.slug}`}
                                    class="text-xl font-bold link no-underline hover:underline w-fit"
                                >
                                    {b.data.title}
                                </a>
                                {!b.data.publish && (
                                    <span class="badge badge-sm badge-neutral">
                                        DRAFT
                                    </span>
                                )}
                            </div>

                            <p>{b.data.description}</p>
                            <ul class="flex flex-row gap-1 flex-wrap">
                                {b.data.tags &&
                                    b.data.tags.map((tag) => (
                                        <li class="badge badge-ghost badge-sm">
                                            {tag}
                                        </li>
                                    ))}
                            </ul>
                        </div>
                    </li>
                ))
            }
        </ul>
    </main>
</Layout>
