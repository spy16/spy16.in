---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tracker</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a0a0a; color: #e0e0e0; min-height: 100dvh; }

    /* Password Gate */
    #gate { display: flex; align-items: center; justify-content: center; min-height: 100dvh; }
    #gate form { display: flex; flex-direction: column; gap: 12px; align-items: center; }
    #gate input { background: #1a1a1a; border: 1px solid #333; color: #e0e0e0; padding: 12px 16px; border-radius: 8px; font-size: 16px; width: 240px; text-align: center; outline: none; }
    #gate input:focus { border-color: #4ade80; }
    #gate .err { color: #f87171; font-size: 13px; min-height: 18px; }

    /* Dashboard */
    #dash { display: none; max-width: 720px; margin: 0 auto; padding: 24px 16px; }
    .header { text-align: center; margin-bottom: 32px; }
    .header h1 { font-size: 24px; font-weight: 700; color: #4ade80; }
    .header p { color: #888; font-size: 14px; margin-top: 4px; }

    /* Stats Grid */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 32px; }
    .stat { background: #141414; border: 1px solid #222; border-radius: 12px; padding: 16px; text-align: center; }
    .stat .val { font-size: 28px; font-weight: 700; color: #fff; }
    .stat .label { font-size: 12px; color: #888; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat.good .val { color: #4ade80; }
    .stat.warn .val { color: #fbbf24; }

    /* Charts */
    .chart-card { background: #141414; border: 1px solid #222; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .chart-card h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: #ccc; }
    .chart-wrap { position: relative; width: 100%; max-height: 300px; }

    /* Streak Calendar */
    .streak { display: flex; flex-wrap: wrap; gap: 4px; }
    .streak .day { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; }
    .streak .day.done { background: #166534; color: #4ade80; }
    .streak .day.missed { background: #1c1c1c; color: #555; }
    .streak .day.future { background: transparent; border: 1px solid #222; color: #333; }

    /* Today */
    .today-card { background: #141414; border: 1px solid #222; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .today-card h2 { font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #ccc; }
    .checklist { list-style: none; }
    .checklist li { padding: 8px 0; border-bottom: 1px solid #1a1a1a; display: flex; align-items: center; gap: 8px; font-size: 14px; }
    .checklist li:last-child { border-bottom: none; }
    .checklist .done { color: #4ade80; }
    .checklist .miss { color: #666; }
    .checklist .icon { font-size: 16px; }
  </style>
</head>
<body>
  <div id="gate">
    <form onsubmit="return unlock(event)">
      <div style="font-size: 32px;">🧊</div>
      <input type="password" id="pw" placeholder="password" autocomplete="off" />
      <div class="err" id="err"></div>
    </form>
  </div>
  <div id="dash"></div>

  <script>
    const PASS_HASH = '5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8'; // sha256 of password

    async function sha256(str) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    async function unlock(e) {
      e.preventDefault();
      const pw = document.getElementById('pw').value;
      const hash = await sha256(pw);
      if (hash === PASS_HASH) {
        sessionStorage.setItem('t_auth', '1');
        loadDashboard();
      } else {
        document.getElementById('err').textContent = 'nope';
      }
      return false;
    }

    if (sessionStorage.getItem('t_auth') === '1') loadDashboard();

    async function loadDashboard() {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('dash').style.display = 'block';

      const res = await fetch('/t/data.json?v=' + Date.now());
      const data = await res.json();
      const { profile, days } = data;

      const latest = days[days.length - 1];
      const currentWeight = latest?.weight_kg || profile.start_weight_kg;
      const bmi = (currentWeight / ((profile.height_cm / 100) ** 2)).toFixed(1);
      const lost = (profile.start_weight_kg - currentWeight).toFixed(1);
      const toGo = (currentWeight - profile.target_weight_kg).toFixed(1);
      const totalDays = days.length;
      const walkDays = days.filter(d => d.walk?.done).length;

      // Streak calc
      let streak = 0;
      for (let i = days.length - 1; i >= 0; i--) {
        if (days[i].walk?.done) streak++; else break;
      }

      const dash = document.getElementById('dash');
      dash.innerHTML = `
        <div class="header">
          <h1>🧊 Tofu Tracker</h1>
          <p>Day ${totalDays} · Started ${profile.start_date}</p>
        </div>

        <div class="stats">
          <div class="stat"><div class="val">${currentWeight}</div><div class="label">Weight (kg)</div></div>
          <div class="stat ${parseFloat(bmi) < 25 ? 'good' : 'warn'}"><div class="val">${bmi}</div><div class="label">BMI</div></div>
          <div class="stat good"><div class="val">${lost > 0 ? '-' + lost : lost}</div><div class="label">Lost (kg)</div></div>
          <div class="stat"><div class="val">${toGo}</div><div class="label">To Go (kg)</div></div>
          <div class="stat good"><div class="val">${streak}</div><div class="label">Walk Streak</div></div>
          <div class="stat"><div class="val">${walkDays}/${totalDays}</div><div class="label">Walk Rate</div></div>
        </div>

        <div class="chart-card">
          <h2>Weight Progress</h2>
          <div class="chart-wrap"><canvas id="weightChart"></canvas></div>
        </div>

        <div class="chart-card">
          <h2>Walk Streak</h2>
          <div class="streak" id="streakCal"></div>
        </div>

        <div class="today-card">
          <h2>Today — ${latest?.date || '...'}</h2>
          <ul class="checklist" id="todayList"></ul>
        </div>

        ${latest?.notes ? `<div class="today-card"><h2>Notes</h2><p style="font-size:14px;color:#aaa;">${latest.notes}</p></div>` : ''}
      `;

      // Weight chart
      const weightDays = days.filter(d => d.weight_kg);
      if (weightDays.length > 0) {
        new Chart(document.getElementById('weightChart'), {
          type: 'line',
          data: {
            labels: weightDays.map(d => d.date.slice(5)),
            datasets: [
              {
                label: 'Weight',
                data: weightDays.map(d => d.weight_kg),
                borderColor: '#4ade80',
                backgroundColor: 'rgba(74,222,128,0.1)',
                fill: true,
                tension: 0.3,
                pointRadius: 4,
                pointBackgroundColor: '#4ade80',
              },
              {
                label: 'Target',
                data: weightDays.map(() => profile.target_weight_kg),
                borderColor: '#333',
                borderDash: [5, 5],
                pointRadius: 0,
                fill: false,
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { min: profile.target_weight_kg - 2, max: profile.start_weight_kg + 2, grid: { color: '#1a1a1a' }, ticks: { color: '#666' } },
              x: { grid: { color: '#1a1a1a' }, ticks: { color: '#666' } }
            }
          }
        });
      }

      // Streak calendar
      const cal = document.getElementById('streakCal');
      days.forEach(d => {
        const div = document.createElement('div');
        div.className = 'day ' + (d.walk?.done ? 'done' : 'missed');
        div.textContent = parseInt(d.date.slice(8));
        div.title = d.date + (d.walk?.done ? ` ✓ ${d.walk.minutes}min` : ' ✗');
        cal.appendChild(div);
      });

      // Today checklist
      const list = document.getElementById('todayList');
      if (latest) {
        const items = [
          { label: 'Walk', done: latest.walk?.done, detail: latest.walk?.done ? `${latest.walk.minutes} min` : '' },
          { label: 'Breakfast', done: latest.meals?.breakfast?.followed, detail: latest.meals?.breakfast?.note || '' },
          { label: 'Lunch', done: latest.meals?.lunch?.followed, detail: latest.meals?.lunch?.note || '' },
          { label: 'Dinner', done: latest.meals?.dinner?.followed, detail: latest.meals?.dinner?.note || '' },
        ];
        items.forEach(it => {
          const li = document.createElement('li');
          const cls = it.done === true ? 'done' : (it.done === false ? 'miss' : 'miss');
          const icon = it.done === true ? '✅' : (it.done === null || it.done === undefined ? '—' : '❌');
          li.innerHTML = `<span class="icon">${icon}</span> <span class="${cls}">${it.label}</span> <span style="color:#555;margin-left:auto;font-size:12px">${it.detail}</span>`;
          list.appendChild(li);
        });
      }
    }
  </script>
</body>
</html>
